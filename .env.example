# Self AGI 系统环境配置示例
# 复制此文件为 .env 并修改相应配置

# 数据库配置
DATABASE_URL=sqlite:///./self_agi.db  # SQLite数据库路径
# DATABASE_URL=postgresql://user:password@localhost:5432/self_agi  # PostgreSQL数据库

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production  # 用于JWT令牌签名
ALGORITHM=HS256  # JWT算法
ACCESS_TOKEN_EXPIRE_MINUTES=30  # 访问令牌过期时间

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true  # 开发模式热重载

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/self_agi.log  # 日志文件路径

# 模型配置
MODEL_DEVICE=cpu  # cpu 或 cuda
MODEL_PRECISION=float32  # float32, float16, bfloat16
MODEL_CACHE_DIR=./model_cache  # 模型缓存目录

# 硬件接口配置
HARDWARE_MODE=none  # none, simulation, real
SIMULATION_TYPE=pybullet  # pybullet, gazebo
ROBOT_TYPE=null  # nao, pepper, custom

# 训练配置
TRAINING_DEVICE=cpu  # cpu 或 cuda
TRAINING_BATCH_SIZE=32
TRAINING_LEARNING_RATE=0.001
TRAINING_MAX_EPOCHS=100

# 外部API配置（可选）
# OPENAI_API_KEY=your-openai-api-key
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# GOOGLE_AI_PROJECT_ID=your-google-ai-project-id

# 前端配置
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 监控配置
ENABLE_MONITORING=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=60  # 健康检查间隔（秒）

# 知识库配置
KNOWLEDGE_BASE_ENABLED=true
VECTOR_STORE_TYPE=faiss  # faiss, hnswlib
EMBEDDING_MODEL=all-MiniLM-L6-v2  # SentenceTransformer模型

# 机器人控制配置
ROBOT_CONTROL_ENABLED=false
ROBOT_SAFETY_ENABLED=true
MAX_JOINT_VELOCITY=1.0  # 最大关节速度（弧度/秒）
MAX_JOINT_TORQUE=5.0  # 最大关节扭矩（Nm）